{
  "name": "zad-app",
  "version": "1.0.0",
  "description": "تطبيق زادُ الخَيْر - رفيقك الإيماني اليومي",
  "main": "index.html",
  "scripts": {
    "dev": "npx serve .",
    "build": "npm run build:speed-insights && npm run build:analytics",
    "build:speed-insights": "esbuild speed-insights.js --bundle --format=iife --outfile=speed-insights.bundle.js",
    "build:analytics": "esbuild analytics.js --bundle --format=iife --outfile=analytics.bundle.js",
    "test": "echo \"No tests specified\""
  },
